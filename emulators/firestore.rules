rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // Helper Functions
    // =========================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    // =========================================================================
    // RBAC Helper Functions (LLC-level)
    // =========================================================================

    // Check if user is the platform owner (bypasses all access checks)
    function isPlatformSuperAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isPlatformSuperAdmin == true;
    }

    // Get user's LLC member document
    function memberDoc(llcId) {
      return get(/databases/$(database)/documents/llcs/$(llcId)/members/$(request.auth.uid));
    }

    // Check if user is an LLC admin (via members collection)
    function isLlcAdmin(llcId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/llcs/$(llcId)/members/$(request.auth.uid)) &&
        memberDoc(llcId).data.status == "active" &&
        memberDoc(llcId).data.role == "admin";
    }

    // Check if user is an active member of an LLC (legacy support)
    function isMember(llcId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/llcs/$(llcId)/members/$(request.auth.uid)) &&
        memberDoc(llcId).data.status == "active";
    }

    // Get user's role in an LLC
    function role(llcId) {
      return memberDoc(llcId).data.role;
    }

    // Check if user has one of the specified roles
    function hasRole(llcId, roles) {
      return isMember(llcId) && roles.hasAny([role(llcId)]);
    }

    // Property scoping: if user has property scopes, limit access
    function canAccessProperty(llcId, propertyId) {
      let scopes = memberDoc(llcId).data.propertyScopes;
      return scopes == null || scopes.size() == 0 || scopes.hasAny([propertyId]);
    }

    // Case scoping: restricted cases require explicit access
    function canAccessCase(llcId, caseId) {
      let r = role(llcId);
      let scopes = memberDoc(llcId).data.caseScopes;
      return r == "admin" || r == "legal" || (scopes != null && scopes.hasAny([caseId]));
    }

    // =========================================================================
    // Account Helper Functions (Multi-tenant layer)
    // =========================================================================

    // Check if user is an active member of an account (owner or admin)
    function isAccountMember(accountId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/accounts/$(accountId)/accountMembers/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/accounts/$(accountId)/accountMembers/$(request.auth.uid)).data.status == "active";
    }

    // Check if user is the owner of an account
    function isAccountOwner(accountId) {
      return isAccountMember(accountId) &&
        get(/databases/$(database)/documents/accounts/$(accountId)/accountMembers/$(request.auth.uid)).data.role == "owner";
    }

    // Check if user is an account member of the account that owns a given LLC
    function isLlcAccountMember(llcId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/llcs/$(llcId)) &&
        get(/databases/$(database)/documents/llcs/$(llcId)).data.accountId != null &&
        isAccountMember(get(/databases/$(database)/documents/llcs/$(llcId)).data.accountId);
    }

    // =========================================================================
    // Users (Unified user collection)
    // =========================================================================

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow read: if isPlatformSuperAdmin();
      allow write: if false; // Admin SDK only
    }

    // =========================================================================
    // User Assignments (RBAC)
    // =========================================================================

    match /userAssignments/{assignmentId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isPlatformSuperAdmin();
      allow write: if false; // Admin SDK only
    }

    // =========================================================================
    // Global Tasks
    // =========================================================================

    match /globalTasks/{taskId} {
      allow read: if isSignedIn() && resource.data.assignedToUserId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.createdByUserId == request.auth.uid;
      allow read: if isPlatformSuperAdmin();
      allow read: if isSignedIn() &&
        resource.data.llcId != null &&
        isLlcAdmin(resource.data.llcId);
      allow write: if false; // Admin SDK only
    }

    // =========================================================================
    // Accounts (Multi-tenant — replaces platformAccounts)
    // =========================================================================

    match /accounts/{accountId} {
      allow read: if isPlatformSuperAdmin();
      allow read: if isAccountMember(accountId);
      allow write: if false; // Admin SDK only

      match /accountMembers/{userId} {
        allow read: if isPlatformSuperAdmin();
        allow read: if isAccountMember(accountId);
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if false; // Admin SDK only
      }
    }

    // =========================================================================
    // Global Tenants
    // =========================================================================

    match /tenants/{tenantId} {
      // Super-admin sees all
      allow read, write: if isPlatformSuperAdmin();
      // Account members can read/write tenants in their account
      allow read: if isSignedIn() &&
        resource.data.accountId != null &&
        isAccountMember(resource.data.accountId);
      allow write: if isSignedIn() &&
        request.resource.data.accountId != null &&
        isAccountMember(request.resource.data.accountId);
      // Tenant portal users can read their own record
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // =========================================================================
    // LLCs
    // =========================================================================

    match /llcs/{llcId} {
      allow read: if isPlatformSuperAdmin();
      allow read: if isMember(llcId);
      allow read: if isLlcAccountMember(llcId);
      allow write: if isPlatformSuperAdmin();
      allow write: if hasRole(llcId, ["admin"]);
      allow write: if isLlcAccountMember(llcId);
    }

    match /llcs/{llcId}/members/{userId} {
      allow read: if isPlatformSuperAdmin();
      allow read: if isMember(llcId);
      allow read: if isLlcAccountMember(llcId);
      allow write: if isPlatformSuperAdmin();
      allow write: if hasRole(llcId, ["admin"]);
      allow write: if isLlcAccountMember(llcId);
    }

    // =========================================================================
    // Properties & Units
    // =========================================================================

    match /llcs/{llcId}/properties/{propertyId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if isMember(llcId) && canAccessProperty(llcId, propertyId);
      allow create, update, delete: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow create, update, delete: if hasRole(llcId, ["admin", "manager"]);
    }

    match /llcs/{llcId}/properties/{propertyId}/units/{unitId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if isMember(llcId) && canAccessProperty(llcId, propertyId);
      allow create, update, delete: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow create, update, delete: if hasRole(llcId, ["admin", "manager"]);
    }

    // =========================================================================
    // Tenants (LLC-scoped)
    // =========================================================================

    match /llcs/{llcId}/tenants/{tenantId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if hasRole(llcId, ["admin", "manager", "legal", "accounting"]);
      allow read: if role(llcId) == "tenant" && resource.data.userId == request.auth.uid;
      allow write: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow write: if hasRole(llcId, ["admin", "manager", "legal"]);
    }

    // =========================================================================
    // Leases
    // =========================================================================

    match /llcs/{llcId}/leases/{leaseId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if isMember(llcId) && (
        hasRole(llcId, ["admin", "manager", "legal", "accounting"]) ||
        (role(llcId) == "tenant" && request.auth.uid in resource.data.tenantUserIds)
      );
      allow write: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow write: if hasRole(llcId, ["admin", "manager", "legal"]);
    }

    match /llcs/{llcId}/leases/{leaseId}/documents/{docId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if hasRole(llcId, ["admin", "manager", "legal", "accounting"]);
      allow write: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow write: if hasRole(llcId, ["admin", "manager"]);
    }

    // =========================================================================
    // Charges & Payments
    // =========================================================================

    match /llcs/{llcId}/charges/{chargeId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if hasRole(llcId, ["admin", "manager", "accounting", "legal"]);
      allow read: if role(llcId) == "tenant" && request.auth.uid == resource.data.tenantUserId;
      allow write: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow write: if hasRole(llcId, ["admin", "accounting"]);
    }

    match /llcs/{llcId}/payments/{paymentId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if hasRole(llcId, ["admin", "manager", "accounting", "legal"]);
      allow read: if role(llcId) == "tenant" && request.auth.uid == resource.data.tenantUserId;
      allow create: if role(llcId) == "tenant";
      allow update, delete: if false; // Functions only (webhook)
    }

    // =========================================================================
    // Ledger (Functions only)
    // =========================================================================

    match /llcs/{llcId}/ledgerEntries/{entryId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if hasRole(llcId, ["admin", "accounting", "manager"]);
      allow write: if false; // Functions only
    }

    // =========================================================================
    // Bills & Vendors
    // =========================================================================

    match /llcs/{llcId}/vendors/{vendorId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if hasRole(llcId, ["admin", "manager", "accounting"]);
      allow write: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow write: if hasRole(llcId, ["admin", "accounting"]);
    }

    match /llcs/{llcId}/bills/{billId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if hasRole(llcId, ["admin", "manager", "accounting"]);
      allow write: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow write: if hasRole(llcId, ["admin", "accounting"]);
    }

    match /llcs/{llcId}/utilityAccounts/{utilityId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if hasRole(llcId, ["admin", "manager", "accounting"]);
      allow write: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow write: if hasRole(llcId, ["admin", "accounting"]);
    }

    // =========================================================================
    // Work Orders
    // =========================================================================

    match /llcs/{llcId}/workOrders/{workOrderId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if hasRole(llcId, ["admin", "manager", "maintenance"]);
      allow read: if role(llcId) == "tenant" && resource.data.requestedByTenantId == request.auth.uid;
      allow read: if isSignedIn() && request.auth.uid in resource.data.assignedEmployeeIds;
      allow create: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow create: if hasRole(llcId, ["admin", "manager", "maintenance", "tenant"]);
      allow update: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow update: if hasRole(llcId, ["admin", "manager", "maintenance"]);
      allow update: if isSignedIn() && request.auth.uid in resource.data.assignedEmployeeIds;
      allow delete: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow delete: if hasRole(llcId, ["admin", "manager"]);
    }

    // =========================================================================
    // Legal Cases
    // =========================================================================

    match /llcs/{llcId}/cases/{caseId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if isMember(llcId) && canAccessCase(llcId, caseId);
      allow write: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow write: if hasRole(llcId, ["admin", "legal"]);
    }

    match /llcs/{llcId}/cases/{caseId}/tasks/{taskId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if isMember(llcId) && canAccessCase(llcId, caseId);
      allow write: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow write: if hasRole(llcId, ["admin", "legal"]);
    }

    match /llcs/{llcId}/cases/{caseId}/documents/{docId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if isMember(llcId) && canAccessCase(llcId, caseId);
      allow write: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow write: if hasRole(llcId, ["admin", "legal"]);
    }

    match /llcs/{llcId}/cases/{caseId}/courtDates/{courtDateId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if isMember(llcId) && canAccessCase(llcId, caseId);
      allow write: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow write: if hasRole(llcId, ["admin", "legal"]);
    }

    // =========================================================================
    // Lease Templates
    // =========================================================================

    match /llcs/{llcId}/leaseTemplates/{templateId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if hasRole(llcId, ["admin", "manager", "legal"]);
      allow write: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow write: if hasRole(llcId, ["admin"]);
    }

    // =========================================================================
    // Audit Logs (Read-only, Functions write)
    // =========================================================================

    match /llcs/{llcId}/auditLogs/{logId} {
      allow read: if isPlatformSuperAdmin() || isLlcAccountMember(llcId);
      allow read: if hasRole(llcId, ["admin", "legal", "accounting"]);
      allow write: if false; // Functions only
    }

    // =========================================================================
    // Stripe Events (Platform-level idempotency tracking)
    // =========================================================================

    match /stripeEvents/{eventId} {
      allow read, write: if false; // Functions only
    }

    // =========================================================================
    // Mortgages (Global collection - Super-admin only)
    // =========================================================================

    match /mortgages/{mortgageId} {
      allow read, write: if isPlatformSuperAdmin();

      match /payments/{paymentId} {
        allow read, write: if isPlatformSuperAdmin();
      }
    }
  }
}
